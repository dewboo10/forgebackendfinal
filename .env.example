# ── Server ──────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/forge_db

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Telegram ─────────────────────────────────────────────────
BOT_TOKEN=your_telegram_bot_token_here
BOT_USERNAME=your_bot_username

# ── TON Payments ─────────────────────────────────────────────
TON_WALLET=your_ton_wallet_address
TON_API_KEY=your_tonapi_key
TON_NETWORK=mainnet   # or testnet

# ── Admin Panel ──────────────────────────────────────────────
ADMIN_SECRET=change_this_strong_secret_min_32_chars
ADMIN_PASSWORD=change_this_admin_password
JWT_SECRET=change_this_jwt_secret_min_32_chars

# ── App ──────────────────────────────────────────────────────
FRONTEND_URL=https://your-telegram-mini-app-url.com
